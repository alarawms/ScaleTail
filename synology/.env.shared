# ScaleTail Synology - Shared Environment
# This file is loaded by all services via env_file in compose.yaml.
# Set your Tailscale auth key below. All services will use this key
# unless overridden in their individual .env file.
#
# Generate a key at: https://login.tailscale.com/admin/settings/keys
# Recommended: reusable + ephemeral key with appropriate tags.

TS_AUTHKEY=
